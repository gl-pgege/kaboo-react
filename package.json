{
  "name": "kaboo-react",
  "version": "0.1.0",
  "description": "Reusable React components and hooks for kaboo-workflows agent activity UI",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kaboo/kaboo-workflows.git",
    "directory": "kaboo-react"
  },
  "homepage": "https://github.com/kaboo/kaboo-workflows/tree/main/kaboo-react#readme",
  "keywords": [
    "react",
    "copilotkit",
    "ag-ui",
    "agents",
    "kaboo",
    "strands"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./copilotkit": {
      "types": "./dist/copilotkit.d.ts",
      "import": "./dist/copilotkit.js",
      "require": "./dist/copilotkit.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@copilotkit/react-core": ">=1.62.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@copilotkit/react-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@copilotkit/react-core": "^1.62.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^29.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^2"
  }
}
